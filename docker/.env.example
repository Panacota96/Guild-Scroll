# Guild Scroll Docker Configuration
# Copy to .env and customize as needed

# Docker Compose Settings
COMPOSE_PROJECT_NAME=guild-scroll
DOCKER_BUILDKIT=1
BUILDKIT_PROGRESS=plain

# Optional image overrides (if you want to pin/pull specific tags)
GUILD_SCROLL_APP_IMAGE=guild-scroll:latest
GUILD_SCROLL_RECORDER_IMAGE=guild-scroll-kali:latest

# Pull policy for docker-compose services:
# - if_not_present (default): pull only if missing
# - always: always pull from registry
# - never: do not pull (offline/local-only mode)
GUILD_SCROLL_PULL_POLICY=if_not_present

# Guild Scroll Configuration
GUILD_SCROLL_DIR=/work/guild_scroll
PYTHONUNBUFFERED=1

# Web Server
WEB_PORT=8080
WEB_HOST=0.0.0.0

# Session Recording
GUILD_SCROLL_SESSION=default-session

# Kali Container Type
# Use 'default' for debian:bookworm-slim (no auth required)
# Use 'official' for kalilinux/kali:rolling (requires docker login)
KALI_BASE_IMAGE=default

# Storage
VOLUME_SIZE=10Gi
RECORDER_VOLUME_SIZE=20Gi

# Kubernetes (if using k8s/)
K8S_NAMESPACE=guild-scroll
K8S_REPLICAS=1
K8S_STORAGE_CLASS=standard
